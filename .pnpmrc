# pnpm-only settings. Read by pnpm alongside .npmrc (pnpm prefers .pnpmrc
# for keys pnpm-specifically understands). Moved out of .npmrc by audit #36
# so a fresh `npm install` of this package does not print "Unknown config"
# warnings — npm reads .npmrc strictly and rejects unknown keys loudly.
#
# Supply-chain hardening
# ---------------------
# Wait 3 days (4320 minutes) after a package is published before installs of
# that new version are honoured. Closes the typo-squat / compromise window
# where a yanked malicious version propagates before being culled. Reference:
# https://pnpm.io/settings#minimumreleaseage
minimum-release-age=4320
# First-party packages we publish (@cloudflare/*) iterate faster than the
# 3-day window — exclude them so our own release loop stays unblocked.
# pnpm glob syntax for selectors: https://pnpm.io/settings#minimumreleaseageexclude
minimum-release-age-exclude=@cloudflare/*
# Don't apply .pnpmfile.cjs overrides. We don't ship one today; this is a
# belt-and-braces lockout so a future contributor doesn't quietly introduce
# a pnpmfile that rewrites dependency graph semantics in CI vs. local.
ignore-pnpmfile=true
