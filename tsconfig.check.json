{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "declaration": false,
    "declarationMap": false,
    "noEmit": true,
    "outDir": "./.tscheck",
    "rootDir": ".",
    "sourceMap": false
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "scripts/**/*.ts", "scripts/**/*.mjs"],
  "exclude": ["node_modules", "dist", "legacy"]
}
